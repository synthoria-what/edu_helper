APP_NAME=EduHelper API
DB_HOST=ru.synthori.space
DB_PORT=5432
DB_NAME=edu_helper
DB_USER=edu_helper_user
DB_PASSWORD=change-mez
# Or use full connection string instead of DB_* variables:
# DATABASE_URL=postgresql+asyncpg://edu_helper_user:change-me@ru.synthori.space:5432/edu_helper
JWT_SECRET_KEY=change-me-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=https://eduhelper.synthori.space,http://localhost,http://127.0.0.1

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Keep 127.0.0.1 when a host nginx will proxy to Docker services.
# Use 0.0.0.0 only if you temporarily need direct access from outside.
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=8080
